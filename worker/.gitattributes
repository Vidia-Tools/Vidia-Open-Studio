# Set default behavior to LF line endings for all text files
* text=auto eol=lf

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# Python files must use LF
*.py text eol=lf

# Docker files must use LF
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Config files must use LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.conf text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.pdf binary
*.whl binary
