+def _safe_filename_from_url(url: str) -> str:
+    """
+    Derive a safe local filename from a URL path. Fall back to a hashed name if needed.
+    Keeps extensions when present to help remux logic decide correctly.
+    """
+    try:
+        parsed = urllib.parse.urlparse(url)
+        base = os.path.basename(parsed.path)
+    except Exception:
+        base = ""
+    if not base or base in (".", ".."):
+        # Fall back to a hashed name; extension will be inferred later from Content-Type
+        h = hashlib.sha256(url.encode(*ENCODE_ARGS[:1])).hexdigest()  # use utf-8
+        return h
+
+    # Sanitize filename to avoid filesystem issues
+    allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._-"
+    safe = "".join(ch if ch in allowed else "_" for ch in base)
+    # Keep original name without forcing an extension; extension will be inferred from Content-Type if available.
+    return safe
