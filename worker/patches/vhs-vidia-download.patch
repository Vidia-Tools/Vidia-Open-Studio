+def _sanitize_url(url: str) -> str:
+    """
+    Percent-encode unsafe characters in the URL path/query while preserving existing escapes.
+    This avoids urllib InvalidURL errors for spaces and other control characters.
+    """
+    try:
+        parts = urllib.parse.urlsplit(url)
+        # Preserve existing % escapes; encode spaces and other unsafe path chars
+        path = urllib.parse.quote(parts.path, safe="/%._-~")
+        # Re-encode query pairs safely and preserve blank values
+        query = urllib.parse.urlencode(urllib.parse.parse_qsl(parts.query, keep_blank_values=True))
+        return urllib.parse.urlunsplit((parts.scheme, parts.netloc, path, query, parts.fragment))
+    except Exception:
+        # On any parsing issue, fall back to original URL
+        return url
 
