+def _http_download_to_temp(url: str) -> str:
+    """
+    Stream-download a remote file to Comfy temp dir using stdlib HTTP with headers and atomic write.
+    Returns the absolute final path. Raises on failure/empty downloads.
+    """
+    tmp_dir = folder_paths.get_temp_directory()
+    os.makedirs(tmp_dir, exist_ok=True)
+
+    name = _safe_filename_from_url(url)
+    # Defer choosing final name/extension until after inspecting Content-Type
+
+    headers = {
+        "Accept": "video/mp4,video/*;q=0.8,*/*;q=0.5",
+        "User-Agent": "Mozilla/5.0 (compatible; Vidia-Loader/1.0)"
+    }
+    url = _sanitize_url(url)
+    req = urllib.request.Request(url, headers=headers)
+
+    try:
+        with urllib.request.urlopen(req, timeout=120) as resp:
+            # Infer extension from Content-Type when original name lacks an extension
+            content_type = resp.headers.get("Content-Type") or resp.info().get_content_type()
+            base, ext = os.path.splitext(name)
+            final_path = os.path.join(tmp_dir, name)  # default to original
+            if (not ext) and content_type:
+                ct = content_type.split(";")[0].strip().lower()
+                ext_map = {
+                    "video/mp4": ".mp4",
+                    "video/quicktime": ".mov",
+                    "video/webm": ".webm",
+                    "video/x-matroska": ".mkv",
+                }
+                mapped = ext_map.get(ct)
+                if mapped:
+                    final_path = os.path.join(tmp_dir, base + mapped)
+
+            # Prepare partial path and cleanup now that final_path is decided
+            part_path = os.path.join(tmp_dir, base + ".part")
+            try:
+                if os.path.exists(part_path):
+                    os.remove(part_path)
+            except Exception:
+                pass
+
+            with open(part_path, "wb") as out:
+                chunk = resp.read(1024 * 1024)
+                while chunk:
+                    out.write(chunk)
+                    chunk = resp.read(1024 * 1024)
+    except Exception as e:
+        # Ensure partial is removed on error
+        try:
+            if os.path.exists(part_path):
+                os.remove(part_path)
+        except Exception:
+            pass
+        raise Exception(f"HTTP download failed for {url}: {e}")
+
+    if not os.path.isfile(part_path) or os.path.getsize(part_path) == 0:
+        try:
+            if os.path.exists(part_path):
+                os.remove(part_path)
+        except Exception:
+            pass
+        raise Exception(f"Downloaded file is empty for {url}")
+
+    # Atomic move into place
+    os.replace(part_path, final_path)
+    return final_path
+
