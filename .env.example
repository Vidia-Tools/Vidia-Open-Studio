# Vidia Open Studio - canonical environment file (plan section 8.1)
# Copy to .env, fill in values, run setup.sh to distribute.
# setup.sh currently distributes BACKEND secrets only (via `wrangler secret put`).
# Worker env vars are set on the RunPod endpoint; frontend VITE_* values are set in
# the Pages build environment or manually in frontend/.env.local for local dev.

# ============================================================
# WORKER (GPU handler) - consumed as Docker/RunPod env vars
# ============================================================

# Backend base URL for all worker callbacks (progress, videoReady, terminal
# logs, pod heartbeats). REQUIRED in hosted mode; leave empty for local mode.
# Get it from your deployed Cloudflare Worker URL.
#BACKEND_BASE=https://your-backend.example.workers.dev

# Shared secret authenticating worker -> backend callbacks (X-Callback-Secret).
# Generate a long random string; must match the backend's RUNPOD_CALLBACK_SECRET.
#RUNPOD_CALLBACK_SECRET=change-me

# Optional explicit callback URL overrides (default: derived from BACKEND_BASE)
#WEBSOCKET_RELAY_URL=
#VIDEO_READY_URL=
#TERMINAL_LOGS_URL=
#POD_HEARTBEAT_URL=
#HEARTBEAT_PATH=/api/vidiaGeneration/podHeartbeat

# Public domain serving exported videos (R2 exports bucket custom domain).
# Used by the handler's fallback HEAD check.
#EXPORTS_DOMAIN=exports.example.com

# vidia-node (output stage) configuration: R2/S3 upload + backend notify
#VIDIA_BACKEND_URL=https://your-backend.example.workers.dev
#S3_PUBLIC_URL_PREFIX=https://exports.example.com
#S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_BUCKET_NAME=exports
#S3_REGION_NAME=auto

# Deployment mode: "serverless" (RunPod endpoint) or "pod" (interactive dev)
#DEPLOYMENT_MODE=serverless

# Model/node download auth for worker/scripts/fetch_models.py (gated downloads)
#HF_TOKEN=
#CIVITAI_TOKEN=

# Tuning / debug (defaults shown; rarely need changing)
#DEBUG=false
#LOG_WORKFLOW=false
#GEN_HEARTBEAT_INTERVAL=3
#COMFY_HOST=127.0.0.1:8188
#COMFY_POLLING_INTERVAL_MS=250
#COMFY_POLLING_MAX_RETRIES=115200
#COMFY_INACTIVITY_TIMEOUT=900
#COMFY_ATTENTION_ARGS=--force-fp16
#COMFY_VERSION=v0.25.1
#COMFY_OUTPUT_DIR=/ComfyUI/output
#REFRESH_WORKER=false
#ENABLE_WEBSOCKET_PROGRESS=true
#WS_READY_TIMEOUT=15
#SUSPECT_DONE_WINDOW=120
#LOG_THROTTLE_SECONDS=10
#WORKFLOWS_BASE=/
#VIDIA_WORK_DIR=/tmp/vidia

# Path to the ComfyUI log tailed for terminal-log forwarding
#COMFY_LOG_PATH=/tmp/comfy.log

# Directory for atomic runtime config writes (local mode app server)
#VIDIA_CONFIG_DIR=

# Timeout in seconds for the prompt-enhance text stage
#VIDIA_TEXT_STAGE_TIMEOUT=120

# Self-update boot chain (updater.sh -> bootstrap.sh -> start.sh). At boot the
# worker clones the monorepo and refreshes its embedded boot scripts + src/ files,
# then start.sh clones the vidia-open-studio-node. All URLs/refs are
# env-configurable so self-hosters can point at their own forks. If a clone fails
# the embedded (image-baked) copy is used. Defaults point at the public codeberg
# repos on the main branch. Deploy keys are optional (public repos need none);
# set to a path on the persistent volume for private forks.
#VIDIA_DOCKER_REPO_URL=https://codeberg.org/Vidia/Vidia-Open-Studio.git
#VIDIA_DOCKER_REPO_REF=main
#VIDIA_NODE_REPO_URL=https://codeberg.org/Vidia/Vidia-Open-Studio-Nodes.git
#VIDIA_NODE_REPO_REF=main
#VIDIA_DOCKER_DEPLOY_KEY=
#VIDIA_NODE_DEPLOY_KEY=

# Worker mode: "runpod" (serverless SDK + R2 output stage, default) or
# "local" (thin HTTP server, stock save to ComfyUI output dir, no backend).
#VIDIA_MODE=runpod

# Port for the local mode app server (POST /generate, GET /progress SSE)
#APP_SERVER_PORT=8189

# ComfyUI base URL for the local app server when run bare-metal
# (equivalent to the --comfy flag of app_server.py)
#COMFY_URL=http://127.0.0.1:8188

# ============================================================
# BACKEND (Cloudflare Worker) - consumed via wrangler
# Non-secret config lives in backend/wrangler.toml [vars] (see
# backend/wrangler.toml.example). The values below are SECRETS:
# setup.sh distributes them with `wrangler secret put` (never committed,
# never placed in wrangler.toml). Hosted multi-user mode only; local mode
# needs no backend.
# ============================================================

# JWT signing secret for user session tokens. Generate a long random string.
#JWT_SECRET=change-me

# RunPod API key (starts a serverless job). From the RunPod console.
#RUNPOD_API_KEY=

# Shared secret authenticating worker -> backend callbacks. MUST match the
# worker's RUNPOD_CALLBACK_SECRET above.
#RUNPOD_CALLBACK_SECRET=change-me

# Resend API key for transactional email (magic links, video-ready notices).
#EMAIL_API_KEY=

# MailerLite API key + group IDs for newsletter / user sync (optional).
#MAILERLITE_API_KEY=
#MAILERLITE_USERS_GROUP_ID=
#MAILERLITE_NEWSLETTER_GROUP_ID=

# Cloudflare Turnstile secret keys (login + newsletter widgets).
#TURNSTILE_SECRET_KEY_LOGIN=
#TURNSTILE_SECRET_KEY_NEWSLETTER=

# R2 S3-compatible credentials for presigned upload URLs (imports bucket).
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=

# Stripe secret + webhook signing secret. EXPERIMENTAL: only needed if you set
# VIDIA_PAYMENTS_ENABLED=true in wrangler.toml (payments are out of scope for v1).
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=

# Non-secret backend config (ALLOWED_ORIGINS, ADMIN_EMAIL, APP_BASE_URL,
# EMAIL_FROM, ACCOUNT_ID, bucket names/domains, RUNPOD_*_ENDPOINT_ID,
# VIDIA_PAYMENTS_ENABLED, STRIPE_PRICE_ID, CHECKOUT_RETURN_URL) is set in
# backend/wrangler.toml, not here. See backend/wrangler.toml.example.

# ============================================================
# FRONTEND (Vite SPA) - consumed as VITE_* build-time vars
# URLs and public keys ONLY, never secret keys (plan 8.1). setup.sh does NOT write
# frontend env; set VITE_* in the Pages build environment, or manually in
# frontend/.env.local for local development. The static admin page (public/js/
# config.js) is also NOT filled by setup.sh.
# ============================================================

# Backend API base URL the SPA talks to. Hosted: your Cloudflare Worker URL.
# Local mode: point at the localhost app_server (worker/app_server.py), e.g.
# http://127.0.0.1:8000 . Selects the backend via the VITE_API_BASE switch.
#VITE_API_BASE=https://your-backend.example.workers.dev

# Mode switches. RUNPOD=hosted backend relay; set false for local app_server.
# DEV_MODE talks straight to a local ComfyUI /prompt endpoint (dev only).
#VITE_RUNPOD_MODE=true
#VITE_DEV_MODE=false

# Cloudflare Turnstile public site key for the login/signup widget (public).
#VITE_TURNSTILE_SITE_KEY_LOGIN=0xYOUR_TURNSTILE_SITE_KEY

# Admin email that unlocks the admin UI / debug mode in the SPA.
#VITE_ADMIN_EMAIL=admin@example.com

# Public exports domain used to build result video URLs (R2 custom domain).
#VITE_EXPORTS_DOMAIN=https://exports.example.com

# Optional overrides for where the controls manifests + modes.json are served
# (defaults: /controls and /js/config/modes.json). Used by local/hosted v1.1.
#VITE_CONTROLS_BASE=/controls
#VITE_MODES_URL=/js/config/modes.json

# OpenRouter API key for the prompt-enhance LLM stage (dev/self-hoster configures;
# never a client-side input). Used by workflows/prompt_prep.json.
#OPENROUTER_API_KEY=
